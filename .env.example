# Frontend (Vite) — only VITE_-prefixed vars are exposed to the browser.
# Never put secrets in here.
#
# Leave VITE_API_BASE_URL unset for local dev — the Vite dev server
# proxies /api/* to the local Worker on :8787 (see apps/web/vite.config.ts).
# In production builds (e.g. on the Cloudflare Pages project), set it to
# the deployed Worker origin so the SPA on *.pages.dev knows where the
# API lives.
#
# VITE_API_BASE_URL=https://university-hub-v2.<your-account>.workers.dev

VITE_APP_NAME=University Hub
