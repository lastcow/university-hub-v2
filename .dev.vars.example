APP_ENV=development
APP_NAME=University Hub
APP_BASE_URL=http://localhost:5173

# Comma-separated origins allowed to call /api/* with credentials. In dev,
# http://localhost:5173 is included automatically; this var is mainly here
# for parity with production. In production, set it to the Pages origin
# (and optionally `https://*.<project>.pages.dev` for previews).
# ALLOWED_WEB_ORIGINS=https://university-hub-v2-web.pages.dev

SESSION_COOKIE_NAME=university_hub_session
SESSION_SECRET=replace-with-local-secret

# Cookie name for the long-lived "Remember this device" trusted-device
# cookie issued after a successful TOTP challenge for university_admin
# (UNI-47). Defaults to "university_hub_device_trust" when unset. The
# cookie is HttpOnly and HMAC'd with SESSION_SECRET; the trust window
# is configurable at runtime via PATCH /api/settings/system.
# TRUSTED_DEVICE_COOKIE_NAME=university_hub_device_trust

# Session lifecycle (UNI-26). Defaults apply when unset:
#   SESSION_IDLE_TIMEOUT_SECONDS     30 min (1800)
#   SESSION_ABSOLUTE_TIMEOUT_SECONDS 12 h   (43200)
# Set explicitly to override; non-numeric or zero values fall back to defaults.
# SESSION_IDLE_TIMEOUT_SECONDS=1800
# SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200

MAILGUN_API_KEY=replace-with-mailgun-api-key
MAILGUN_DOMAIN=replace-with-mailgun-domain
MAILGUN_FROM_EMAIL=no-reply@example.com
MAILGUN_FROM_NAME=University Hub
MAILGUN_REGION=US

# Where /api/contact notifications are delivered (set this to a real inbox in
# production). Falls back to MAILGUN_FROM_EMAIL when unset.
SUPPORT_EMAIL=support@example.com

# Production bootstrap (UNI-16). Leave UNSET in dev — the dev seed migration
# already creates a super_admin (`superadmin@dev.local`). In production, set
# this to a long random secret with `wrangler secret put BOOTSTRAP_SECRET`,
# run `npm run bootstrap:admin -- --url=... --email=...`, and then delete the
# secret with `wrangler secret delete BOOTSTRAP_SECRET`. See docs/auth.md.
# BOOTSTRAP_SECRET=replace-with-bootstrap-secret

# Rate-limit overrides (UNI-25). Defaults are documented in
# apps/worker/src/middleware/rate-limit.ts. Override only when an operator
# wants different ceilings for the deployed instance. All values are positive
# integers; non-numeric or zero values fall back to the default.
# RATE_LIMIT_SIGN_IN_MAX=5
# RATE_LIMIT_SIGN_IN_WINDOW_SECONDS=900
# RATE_LIMIT_PASSWORD_RESET_MAX=3
# RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=3600
# RATE_LIMIT_MFA_CHALLENGE_MAX=5
# RATE_LIMIT_MFA_CHALLENGE_WINDOW_SECONDS=300
# RATE_LIMIT_INVITATION_RESEND_MAX=3
# RATE_LIMIT_INVITATION_RESEND_WINDOW_SECONDS=3600
# RATE_LIMIT_API_AUTH_MAX=120
# RATE_LIMIT_API_AUTH_WINDOW_SECONDS=60
# RATE_LIMIT_API_ANON_MAX=30
# RATE_LIMIT_API_ANON_WINDOW_SECONDS=60

# Retention sweep overrides (UNI-33). All values are positive integers in
# *days*; defaults below match the FERPA-aligned baseline documented in
# docs/data-retention.md. Override per-customer when an institution's
# policy differs (e.g. shorter audit retention for a state university,
# longer educational retention for a graduate school).
#
# RETENTION_DRY_RUN=1                          # log the plan, do nothing
# RETENTION_EDUCATIONAL_DAYS=2555              # grades / assessments / course_assignments (~7y)
# RETENTION_AUDIT_LOG_DAYS=2555                # audit_logs (~7y)
# RETENTION_GRADE_ACCESS_LOG_DAYS=2555         # FERPA §99.32 record-of-disclosure (~7y)
# RETENTION_EMAIL_LOG_DAYS=90
# RETENTION_SOFT_DELETED_DAYS=365              # assessments.deleted_at < cutoff
# RETENTION_SESSION_PURGE_DAYS=30
# RETENTION_RATE_LIMIT_PURGE_DAYS=30
# RETENTION_MFA_CHALLENGE_PURGE_DAYS=30
# RETENTION_PARENT_TOKEN_PURGE_DAYS=30
# RETENTION_PARENT_SESSION_PURGE_DAYS=30
#
# Ultimate-retention windows applied to the archive shadow tables.
# Email-archived purge defaults to 1 year per the sub-issue spec. The rest
# default to "never auto-purge" — set a positive number to opt in.
# RETENTION_ARCHIVE_EMAIL_DAYS=365
# RETENTION_ARCHIVE_AUDIT_LOG_DAYS=
# RETENTION_ARCHIVE_GRADE_ACCESS_LOG_DAYS=
# RETENTION_ARCHIVE_GRADES_DAYS=
# RETENTION_ARCHIVE_ASSESSMENTS_DAYS=
# RETENTION_ARCHIVE_COURSE_ASSIGNMENTS_DAYS=
