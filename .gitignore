# Dependencies
node_modules/

# Build output
dist/
build/
out/
.tsout/
*.tsbuildinfo

# Cloudflare / Wrangler
.wrangler/
.dev.vars
.mf/

# Local env
.env
.env.*
!.env.example
!.dev.vars.example
# UNI-46: the SPA's default-tenant production env is committed on purpose
# (codifies VITE_API_BASE_URL so `wrangler pages deploy` from a fresh
# checkout can't ship a bundle that calls relative /api/... paths). Per-
# tenant overrides go through shell env, not a sibling .env.production.
!apps/web/.env.production

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editors
.vscode/
.idea/
*.swp
.DS_Store

# Coverage
coverage/
*.lcov

# Misc
.cache/
.tmp/

# Local screenshots produced by scripts/screenshot-mfa.mjs
screenshots/

# Per-tenant provisioning artifacts produced by scripts/provision-university.mjs.
# Each tenant's wrangler.toml holds the D1 database_id and the Worker name —
# Cloudflare resource identifiers, not secrets, but not interesting to commit.
provisioning/*
!provisioning/.gitkeep
!provisioning/README.md

# Incident-response forensic artefacts (see docs/incident-response.md).
# D1 dumps + hashes captured during a security incident land here; never
# commit them.
incidents/
