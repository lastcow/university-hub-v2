{
  "name": "university-hub-v2",
  "private": true,
  "version": "0.0.0",
  "description": "University Hub v2 — SaaS-style university management platform on Cloudflare.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n worker,web -c blue,magenta \"npm:dev:worker\" \"npm:dev:web\"",
    "dev:worker": "npm --workspace @university-hub/worker run dev",
    "dev:web": "npm --workspace @university-hub/web run dev",
    "build": "npm --workspace @university-hub/web run build",
    "typecheck": "tsc -b --pretty",
    "typecheck:clean": "tsc -b --clean",
    "test": "npm --workspace @university-hub/worker run test",
    "db:migrate:local": "npm --workspace @university-hub/worker run db:migrate:local",
    "db:migrate": "npm --workspace @university-hub/worker run db:migrate",
    "db:exec:local": "npm --workspace @university-hub/worker run db:exec:local",
    "db:exec": "npm --workspace @university-hub/worker run db:exec"
  },
  "devDependencies": {
    "concurrently": "9.1.0",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
