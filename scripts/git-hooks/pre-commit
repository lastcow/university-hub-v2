#!/usr/bin/env bash
# pre-commit — UNI-29 secret-scan gate, UNI-38 bypass discipline.
#
# Greps the staged diff for common secret prefixes and aborts the commit if
# any are found. This is a defense-in-depth check on top of GitHub's
# built-in secret scanning (which catches things post-push); the goal is
# to stop a leaked credential before it ever reaches the remote.
#
# Activated by `git config core.hooksPath scripts/git-hooks`, which the
# repo's `npm install` runs via the `postinstall` script (see
# scripts/setup-git-hooks.mjs).
#
# Bypass: requires BOTH `SKIP_SECRET_SCAN=1` AND a non-empty
# `SKIP_SECRET_SCAN_REASON` env var. The hook prints a loud stderr
# banner with the reason, the user, and the staged context so that
# bypassed commits are auditable. The reason should also be in the
# commit message body or PR description. See docs/security-ci.md.

set -eu

if [ "${SKIP_SECRET_SCAN:-}" = "1" ]; then
  reason="${SKIP_SECRET_SCAN_REASON:-}"
  if [ -z "$reason" ]; then
    cat >&2 <<'EOF'
pre-commit: SKIP_SECRET_SCAN=1 set without SKIP_SECRET_SCAN_REASON.
Refusing to bypass the secret scan silently.

Set SKIP_SECRET_SCAN_REASON to a one-line justification, e.g.:

  SKIP_SECRET_SCAN=1 \
  SKIP_SECRET_SCAN_REASON="test fixture: fake AKIA-prefixed AWS key in apps/worker/test/auth.test.ts" \
    git commit ...

The reason is logged to stderr and should also appear in the commit
message body or PR description so the bypass is auditable.
See docs/security-ci.md (section 5b) for when bypass is appropriate.
EOF
    exit 1
  fi

  user_email=$(git config user.email 2>/dev/null || echo '(git config user.email unset)')
  branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null || echo '(detached HEAD)')
  timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)

  # Best-effort commit-subject capture from the parent git process.
  # Pre-commit runs before COMMIT_EDITMSG is written, so the subject is
  # not directly available. On Linux we can read /proc/$PPID/cmdline
  # and pull the -m / --message argument out of the parent's argv.
  # Falls back to a placeholder on platforms without /proc.
  subject=""
  if [ -r "/proc/$PPID/cmdline" ]; then
    _argv=()
    mapfile -d '' -t _argv < "/proc/$PPID/cmdline" 2>/dev/null || _argv=()
    take_next=0
    for arg in "${_argv[@]}"; do
      if [ "$take_next" = 1 ]; then
        subject="$arg"
        break
      fi
      case "$arg" in
        -m|--message|-F|--file) take_next=1 ;;
        --message=*) subject="${arg#--message=}"; break ;;
        -m*) subject="${arg#-m}"; break ;;
      esac
    done
    # If -F/--file pointed at a file, read its first line as the subject.
    if [ -n "$subject" ] && [ -f "$subject" ] && [ "$take_next" = 1 ]; then
      subject=$(head -n 1 "$subject" 2>/dev/null || echo "$subject")
    fi
  fi
  if [ -z "$subject" ]; then
    subject="(see resulting commit — subject not finalized at pre-commit phase)"
  fi

  staged_files=$(git diff --cached --name-only --diff-filter=ACMRTUXB 2>/dev/null || true)
  staged_count=$(printf '%s\n' "$staged_files" | grep -c . || true)
  staged_count=${staged_count:-0}

  cat >&2 <<EOF

================================================================================
pre-commit: SECRET SCAN BYPASSED (SKIP_SECRET_SCAN=1)
================================================================================
  Reason:   ${reason}
  User:     ${user_email}
  Branch:   ${branch}
  Subject:  ${subject}
  Time:     ${timestamp}
  Staged:   ${staged_count} file(s)
EOF
  if [ -n "$staged_files" ]; then
    printf '%s\n' "$staged_files" | head -5 | while IFS= read -r f; do
      echo "            - $f" >&2
    done
    if [ "$staged_count" -gt 5 ]; then
      echo "            ... and $((staged_count - 5)) more" >&2
    fi
  fi
  cat >&2 <<'EOF'
================================================================================
This bypass is auditable. Make sure the reason is also in the commit
message body or PR description so reviewers can confirm it.
================================================================================

EOF
  exit 0
fi

# Patterns. Keep tight enough to avoid false positives on prose; tight
# enough to catch the credential families we actually use.
#
# Each pattern is `name|regex`. The regex is fed to `grep -E`.
PATTERNS=(
  'AWS Access Key|\bAKIA[0-9A-Z]{16}\b'
  'AWS Secret Key|aws(.{0,20})?(secret|key)(.{0,5})?[=:]\s*"?[A-Za-z0-9/+=]{40}"?'
  'Mailgun key|\bkey-[0-9a-f]{32}\b'
  'Mailgun namespaced key|\bmailgun_[A-Za-z0-9_-]{20,}'
  'Stripe live secret|\bsk_live_[0-9a-zA-Z]{24,}'
  'Stripe live publishable|\bpk_live_[0-9a-zA-Z]{24,}'
  'Stripe restricted|\brk_live_[0-9a-zA-Z]{24,}'
  'GitHub PAT|\bghp_[0-9A-Za-z]{36}\b'
  'GitHub fine-grained PAT|\bgithub_pat_[0-9A-Za-z_]{82}\b'
  'GitHub OAuth/server token|\bgho_[0-9A-Za-z]{36}\b'
  'GitHub user-to-server|\bghu_[0-9A-Za-z]{36}\b'
  'GitHub server-to-server|\bghs_[0-9A-Za-z]{36}\b'
  'GitHub refresh token|\bghr_[0-9A-Za-z]{36}\b'
  'Slack token|\bxox[abprs]-[0-9A-Za-z-]{10,}\b'
  'Google API key|\bAIza[0-9A-Za-z_-]{35}\b'
  'Cloudflare API token|\bcf_[A-Za-z0-9_-]{40,}\b'
  'OpenAI API key|\bsk-[A-Za-z0-9]{20,}\b'
  'Anthropic API key|\bsk-ant-[A-Za-z0-9_-]{40,}\b'
  'Generic private key block|-----BEGIN (RSA |OPENSSH |EC |DSA |PGP )?PRIVATE KEY-----'
  'JWT (3 base64 segments)|\beyJ[A-Za-z0-9_-]{8,}\.eyJ[A-Za-z0-9_-]{8,}\.[A-Za-z0-9_-]{8,}\b'
)

# Files staged for commit, excluding deletions. We diff against the index,
# not the working tree, so the user only gets caught for what they're
# actually about to commit.
mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACMRTUXB)

if [ ${#STAGED[@]} -eq 0 ]; then
  exit 0
fi

# Skip the lockfile (massive, never carries secrets but huge and slow), and
# this hook itself (its `PATTERNS` array would match every commit that
# updates the patterns).
SKIP_REGEX='^(package-lock\.json|scripts/git-hooks/pre-commit)$'

FOUND=0
for f in "${STAGED[@]}"; do
  [ -f "$f" ] || continue
  if [[ "$f" =~ $SKIP_REGEX ]]; then
    continue
  fi
  for entry in "${PATTERNS[@]}"; do
    name="${entry%%|*}"
    regex="${entry#*|}"
    if matches=$(grep -EnH "$regex" -- "$f" 2>/dev/null); then
      if [ "$FOUND" = 0 ]; then
        echo "pre-commit: refusing to commit — possible secrets detected." >&2
        echo >&2
      fi
      FOUND=1
      echo "  [$name] in $f" >&2
      echo "$matches" | sed 's/^/    /' >&2
    fi
  done
done

if [ "$FOUND" = 1 ]; then
  cat >&2 <<'EOF'

If this is a real credential:
  - Rotate it now (do NOT just remove it from the diff — assume it leaked).
  - Then unstage the file and re-commit.
If this is a false positive (test fixture, documentation example, etc.):
  - Run with both SKIP_SECRET_SCAN=1 and SKIP_SECRET_SCAN_REASON="..."
    set, and explain the reason in the commit message too.
See docs/security-ci.md for triage details.
EOF
  exit 1
fi

exit 0
