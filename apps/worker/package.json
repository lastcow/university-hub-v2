{
  "name": "@university-hub/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -b --pretty",
    "dev": "wrangler dev --local --port 8787",
    "build": "wrangler deploy --dry-run --outdir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "db:exec:local": "wrangler d1 execute DB --local",
    "db:exec": "wrangler d1 execute DB --remote"
  },
  "dependencies": {
    "@university-hub/shared": "*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260525.1",
    "vitest": "2.1.8",
    "wrangler": "^4.87.0"
  }
}
