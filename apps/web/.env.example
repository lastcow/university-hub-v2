# Frontend (Vite) — only VITE_-prefixed vars are exposed to the browser.
# Never put secrets in here.
#
# When VITE_API_BASE_URL is unset, the API client sends requests to relative
# `/api/...` paths and the Vite dev server (vite.config.ts) proxies them to
# the local Worker on :8787. Set it in production builds (e.g. on the
# Cloudflare Pages project) to the deployed Worker origin so the SPA on
# *.pages.dev knows where the API lives.
#
# VITE_API_BASE_URL=https://university-hub-v2.<your-account>.workers.dev

VITE_APP_NAME=University Hub
